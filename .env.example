# ═══════════════════════════════════════════════════════════════════════════════
# opencode-memnet — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Variables marked Required: yes MUST be set before starting the server.
# Variables with defaults can be left as-is unless you need to customize them.
#
# Secret values (EMBEDDING_API_KEY, MEMORY_API_KEY) support special prefixes:
#   - Plain value:    sk-abc123...
#   - File reference: file:///path/to/secret  (reads contents of file)
#   - Env reference:  env://OTHER_ENV_VAR     (reads another env variable)
#
# ═══════════════════════════════════════════════════════════════════════════════


# ── Server ─────────────────────────────────────────────────────────────────────

# EXTERNAL_HOST
# IP address or hostname on the HOST machine to bind the server port to.
# This controls which network interfaces the server is accessible from.
# Options: localhost | 127.0.0.1 | 0.0.0.0 | <any-ip-address>
# Default: localhost (only accessible from this machine — most secure)
# Set to 0.0.0.0 to allow access from other machines on your network (e.g. LAN access)
# Only used by docker-compose; ignored when running the server directly.
# Required: no
EXTERNAL_HOST=localhost

# HOST_PORT
# Port number on the HOST machine that maps to the container port.
# This is the port you use to access the server from outside Docker.
# Default: 4747
# Only used by docker-compose; ignored when running the server directly.
# Required: no
HOST_PORT=4747

# SERVER_PORT
# Port the HTTP server listens on INSIDE the container (or directly when not
# using Docker). In docker-compose this is the container-side port mapping.
# Default: 4747
# Required: no
SERVER_PORT=4747

# SERVER_HOST
# Network interface the server binds to INSIDE the container. Use "0.0.0.0" for
# all interfaces (required for Docker) or "127.0.0.1" for local-only access
# (only when running outside Docker).
# Default: 0.0.0.0
# Required: no
SERVER_HOST=0.0.0.0

# SERVER_API_KEY
# API key used to authenticate all /api/* requests. Clients must send this as
# a Bearer token. Choose a strong random string for production.
# Optional if both DISABLE_WEBUI_AUTH and DISABLE_CLIENT_AUTH are set to "true".
# Default: (empty — will fail validation unless both auth modes are disabled)
# Required: yes (unless both auth modes are disabled)
# Example: my-secret-api-key-change-me
SERVER_API_KEY=

# DISABLE_WEBUI_AUTH
#
# Normally, when you open the WebUI (the browser dashboard at http://localhost:4747),
# you need to enter your API key before you can see or do anything. This setting
# turns that requirement OFF.
#
# What happens when you set this to "true":
#   - Anyone who can reach the server URL can open the WebUI and see everything —
#     all memories, all profiles, all stats. No login or API key needed.
#   - The browser dashboard still has an "API Settings" panel, but it will show
#     "Auth disabled" and auto-load your data immediately.
#
# Why would you use this?
#   - You're running the server on localhost (your own machine) and don't need
#     a password since only you can access it.
#   - You've put the server behind something that already handles auth — for
#     example, a reverse proxy like Caddy or Nginx with HTTP basic auth, a VPN,
#     or a firewall that only allows your IP address.
#   - You're on a trusted private network (e.g., home LAN) and want convenience
#     over security.
#
# Why would you NOT use this?
#   - If the server is reachable from the internet without any other protection,
#     anyone could read all stored memories and profiles, or add/delete memories.
#     That's bad — memories can contain sensitive project context and personal
#     preferences.
#
# Default: false (API key IS required)
# Required: no
# Example: DISABLE_WEBUI_AUTH=true
DISABLE_WEBUI_AUTH=false

# DISABLE_CLIENT_AUTH
#
# Normally, the opencode-memnet plugin (running inside your AI coding agent) needs
# to send an API key with every request to the server — a sort of password that
# proves "hey, I'm allowed to talk to this server." This setting turns that
# requirement OFF.
#
# What happens when you set this to "true":
#   - The plugin can connect to the server and read/write memories WITHOUT
#     sending an API key. The plugin config file only needs the server URL,
#     not an API key.
#   - ANY client that can reach the server can add, search, and delete memories.
#
# Why would you use this?
#   - You're running everything locally (server + client on the same machine)
#     and don't need inter-process authentication.
#   - You have many AI agents connecting and don't want to manage API keys for
#     each one.
#   - The server is behind a reverse proxy or VPN that already restricts access.
#
# Why would you NOT use this?
#   - If the server is on a network that other people or processes can reach,
#     they could connect to it and read or tamper with your AI's memory store.
#
# Note: You can mix and match. For example, you can set DISABLE_WEBUI_AUTH=true
# (open browser access) but leave DISABLE_CLIENT_AUTH=false (plugin still needs
# the key). Or vice versa. If you set BOTH to "true", then SERVER_API_KEY becomes
# optional — you can omit it entirely.
#
# Default: false (API key IS required)
# Required: no
# Example: DISABLE_CLIENT_AUTH=true
DISABLE_CLIENT_AUTH=false

# WEB_SERVER_ALLOWED_ORIGIN
# CORS Allowed-Origin header value. Use "*" to allow all origins, or specify
# a specific origin like "https://myapp.example.com" for production.
# Default: *
# Required: no
WEB_SERVER_ALLOWED_ORIGIN=*


# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────

# POSTGRES_URL
# Full PostgreSQL connection string. For Docker Compose with the bundled db
# service, use: postgresql://opencode:opencode@db:5432/opencode_mem
# For external databases, provide the full URL including host, port, user,
# password, and database name.
# Default: (empty — will fail validation)
# Required: yes
# Example: postgresql://user:password@localhost:5432/opencode_mem
POSTGRES_URL=

# POSTGRES_SSL
# SSL mode for the PostgreSQL connection. Set to "false" (the string) for local
# Docker development. Set to "require" for production with managed databases.
# Options: | require | false |
# Default: require
# Required: no
POSTGRES_SSL=require

# POSTGRES_MAX_CONNECTIONS
# Maximum number of connections in the PostgreSQL connection pool.
# Default: 10
# Required: no
POSTGRES_MAX_CONNECTIONS=10

# POSTGRES_IDLE_TIMEOUT_SECONDS
# Number of seconds a connection can be idle before being closed.
# Default: 30
# Required: no
POSTGRES_IDLE_TIMEOUT_SECONDS=30

# POSTGRES_CONNECT_TIMEOUT_SECONDS
# Maximum seconds to wait when establishing a new connection.
# Default: 10
# Required: no
POSTGRES_CONNECT_TIMEOUT_SECONDS=10

# POSTGRES_VECTOR_TYPE
# pgvector column type to use for embeddings. Use "vector" for full precision
# or "halfvec" for half-precision (smaller storage, slightly less accurate).
# Options: | vector | halfvec |
# Default: vector
# Required: no
POSTGRES_VECTOR_TYPE=vector

# POSTGRES_HNSW_EF_SEARCH
# HNSW index ef_search parameter. Higher values improve recall at the cost of
# query speed. Range: 1–1000+.
# Default: 128
# Required: no
POSTGRES_HNSW_EF_SEARCH=128

# POSTGRES_HNSW_EF_CONSTRUCTION
# HNSW index ef_construction parameter used during index creation. Higher values
# improve index quality at the cost of build time. Range: 1–1000+.
# Default: 256
# Required: no
POSTGRES_HNSW_EF_CONSTRUCTION=256


# ── Embedding ─────────────────────────────────────────────────────────────────

# EMBEDDING_API_URL
# Base URL for the OpenAI-compatible embedding API endpoint.
# For OpenAI: https://api.openai.com/v1
# For self-hosted (e.g., Ollama): http://localhost:11434/v1
# Default: (empty — will fail validation)
# Required: yes
# Example: https://api.openai.com/v1
EMBEDDING_API_URL=

# EMBEDDING_MODEL
# Name of the embedding model to use. Dimensions are auto-detected for known
# models (see EMBEDDING_DIMENSIONS below).
# Common choices: text-embedding-3-small, text-embedding-3-large, voyage-3
# Default: (empty — will fail validation)
# Required: yes
# Example: text-embedding-3-small
EMBEDDING_MODEL=

# EMBEDDING_API_KEY
# API key for the embedding service. Supports secret prefixes:
#   - Plain:    sk-abc123...
#   - File:     file:///run/secrets/embedding_key
#   - Env ref:  env://MY_EMBEDD_KEY
# Also falls back to OPENAI_API_KEY if this is not set.
# Default: (empty — will fail validation)
# Required: yes (or set OPENAI_API_KEY)
# Example: sk-...
EMBEDDING_API_KEY=

# EMBEDDING_DIMENSIONS
# Override the embedding vector dimensions. Leave unset (or 0) to auto-detect
# from the model name. Auto-detected dimensions for known models:
#   text-embedding-3-small         → 1536
#   text-embedding-3-large         → 3072
#   text-embedding-ada-002         → 1536
#   embed-english-v3.0             → 1024
#   embed-multilingual-v3.0        → 1024
#   embed-english-light-v3.0       → 384
#   embed-multilingual-light-v3.0  → 384
#   text-embedding-004             → 768
#   text-multilingual-embedding-002 → 768
#   voyage-3                       → 1024
#   voyage-3-lite                  → 512
#   voyage-code-3                  → 1024
# Unknown models default to 1024.
# Default: auto-detected from EMBEDDING_MODEL
# Required: no
EMBEDDING_DIMENSIONS=0

# EMBEDDING_MAX_TOKENS_CONTENT
# Maximum tokens for content text before embedding. Excess tokens are truncated
# according to the truncation side setting.
# Default: 2048
# Required: no
EMBEDDING_MAX_TOKENS_CONTENT=2048

# EMBEDDING_MAX_TOKENS_TAGS
# Maximum tokens for tag text before embedding.
# Default: 256
# Required: no
EMBEDDING_MAX_TOKENS_TAGS=256

# EMBEDDING_MAX_TOKENS_QUERY
# Maximum tokens for search queries before embedding.
# Default: 512
# Required: no
EMBEDDING_MAX_TOKENS_QUERY=512

# EMBEDDING_MAX_TOKENS_MIGRATION
# Maximum tokens for migration content before embedding.
# Default: 2048
# Required: no
EMBEDDING_MAX_TOKENS_MIGRATION=2048

# EMBEDDING_TRUNCATION_CONTENT
# Which side to truncate from when content exceeds max tokens.
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_CONTENT=right

# EMBEDDING_TRUNCATION_TAGS
# Truncation side for tag text.
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_TAGS=right

# EMBEDDING_TRUNCATION_QUERY
# Truncation side for search queries.
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_QUERY=right

# EMBEDDING_TRUNCATION_MIGRATION
# Truncation side for migration content.
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_MIGRATION=right


# ── Memory / AI ───────────────────────────────────────────────────────────────

# SIMILARITY_THRESHOLD
# Minimum cosine similarity score (0.0–1.0) for memory search results. Lower
# values return more results but may include less relevant matches.
# Default: 0.6
# Required: no
SIMILARITY_THRESHOLD=0.6

# MAX_MEMORIES
# Maximum number of memories returned in context injection.
# Default: 10
# Required: no
MAX_MEMORIES=10

# INJECT_PROFILE
# Whether to include the learned user profile in context injection.
# Set to "false" to disable profile injection.
# Default: true
# Required: no
INJECT_PROFILE=true

# MEMORY_MODEL
# Chat model used for memory extraction and auto-capture. Required for
# auto-capture functionality. Any OpenAI-compatible Chat Completions model.
# Default: (not set — auto-capture disabled)
# Required: no (but needed for auto-capture)
# Example: gpt-4o-mini
MEMORY_MODEL=

# MEMORY_API_URL
# Base URL for the OpenAI-compatible Chat Completions API used for memory
# extraction. Can be the same as EMBEDDING_API_URL or a different endpoint.
# Default: (not set — auto-capture disabled)
# Required: no (but needed for auto-capture)
# Example: https://api.openai.com/v1
MEMORY_API_URL=

# MEMORY_API_KEY
# API key for the memory extraction Chat Completions API. Supports secret
# prefixes:
#   - Plain:    sk-abc123...
#   - File:     file:///run/secrets/memory_key
#   - Env ref:  env://MY_MEMORY_KEY
# Default: (not set — auto-capture disabled)
# Required: no (but needed for auto-capture)
# Example: sk-...
MEMORY_API_KEY=

# MEMORY_TEMPERATURE
# Temperature for memory generation LLM calls. Set to a number (0.0–2.0) for
# creative generation, or "false" to disable temperature (use API default).
# Default: 0.3
# Required: no
MEMORY_TEMPERATURE=0.3

# OPENCODE_PROVIDER
# OpenCode provider identifier. Used internally for provider-specific behavior.
# Default: (not set)
# Required: no
OPENCODE_PROVIDER=

# OPENCODE_MODEL
# OpenCode model identifier. Used internally for model-specific behavior.
# Default: (not set)
# Required: no
OPENCODE_MODEL=


# ── Auto-Capture ──────────────────────────────────────────────────────────────

# AUTO_CAPTURE_MAX_ITERATIONS
# Maximum number of auto-capture iterations per session. Each iteration processes
# a batch of conversation messages.
# Default: 5
# Required: no
AUTO_CAPTURE_MAX_ITERATIONS=5

# AUTO_CAPTURE_ITERATION_TIMEOUT
# Timeout in milliseconds for each auto-capture iteration.
# Default: 30000
# Required: no
AUTO_CAPTURE_ITERATION_TIMEOUT=30000

# AUTO_CAPTURE_LANGUAGE
# Language for generated memories. Set to a language code (e.g., "en", "zh") or
# "auto" to let the system detect the language.
# Default: auto
# Required: no
AUTO_CAPTURE_LANGUAGE=auto


# ── Session & Cleanup ─────────────────────────────────────────────────────────

# AI_SESSION_RETENTION_DAYS
# Number of days to retain AI session data before automatic cleanup.
# Default: 7
# Required: no
AI_SESSION_RETENTION_DAYS=7

# AUTO_CLEANUP_RETENTION_DAYS
# Number of days to retain memories before automatic cleanup. Set to 0 to
# disable auto-cleanup.
# Default: 90
# Required: no
AUTO_CLEANUP_RETENTION_DAYS=90


# ── User Profile ──────────────────────────────────────────────────────────────

# USER_PROFILE_ANALYSIS_INTERVAL
# Number of sessions between automatic profile analysis runs.
# Default: 10
# Required: no
USER_PROFILE_ANALYSIS_INTERVAL=10

# USER_PROFILE_MAX_PREFERENCES
# Maximum number of learned preferences stored per user profile.
# Default: 20
# Required: no
USER_PROFILE_MAX_PREFERENCES=20

# USER_PROFILE_MAX_PATTERNS
# Maximum number of detected behavior patterns stored per user profile.
# Default: 15
# Required: no
USER_PROFILE_MAX_PATTERNS=15

# USER_PROFILE_MAX_WORKFLOWS
# Maximum number of identified workflows stored per user profile.
# Default: 10
# Required: no
USER_PROFILE_MAX_WORKFLOWS=10

# USER_PROFILE_CONFIDENCE_DECAY_DAYS
# Number of days over which profile confidence scores decay. Older observations
# contribute less to the profile.
# Default: 30
# Required: no
USER_PROFILE_CONFIDENCE_DECAY_DAYS=30

# USER_PROFILE_CHANGELOG_RETENTION
# Number of profile changelog versions to retain.
# Default: 5
# Required: no
USER_PROFILE_CHANGELOG_RETENTION=5


# ── Docker Compose Database Service ──────────────────────────────────────────
# These variables are used by the `db` service in docker-compose.yml ONLY.
# They are NOT read by the opencode-memnet server itself.
# If using an external database, you can ignore these.

# POSTGRES_USER
# PostgreSQL username for the Docker db service.
# Default: opencode
POSTGRES_USER=opencode

# POSTGRES_PASSWORD
# PostgreSQL password for the Docker db service.
# Default: opencode
POSTGRES_PASSWORD=opencode

# POSTGRES_DB
# PostgreSQL database name for the Docker db service.
# Default: opencode_mem
POSTGRES_DB=opencode_mem
